# Local settings. Copy to .env for private values.
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000
PUBLIC_DEMO_MODE=true
MAX_FILES_PER_UPLOAD=5
MAX_UPLOAD_MB=20
JWT_SECRET=replace_with_a_long_random_secret_for_local_run

# Caila is used as an OpenAI-compatible chat API.
LLM_PROVIDER=caila
LLM_BASE_URL=https://caila.io/api/adapters/openai
LLM_API_KEY=your_caila_api_key_here

LLM_MODEL=gpt-4o-mini
LLM_MODEL_QUALITY=gpt-4o-mini

# Retrieval embeddings stay local.
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

CHROMA_PERSIST_DIR=data/vector_store
UPLOAD_DIR=data/uploads
PROCESSED_DIR=data/processed
DEFAULT_TOP_K=4

# Data retention policy for uploaded source files.
UPLOAD_RETENTION_HOURS=24
